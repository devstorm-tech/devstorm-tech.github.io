# Server Configuration
PORT=8000
NODE_ENV=production

# MongoDB Configuration
# For standalone MongoDB (local or non-Atlas): use retryWrites=false query parameter
MONGODB_URI=mongodb://127.0.0.1:27017/devstorm_db?retryWrites=false

# Alternative: MongoDB Atlas connection with retryWrites disabled
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/devstorm_db?retryWrites=false

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email Service Configuration (SMTP)
EMAIL_USER=your-smtp-email@example.com
EMAIL_PASS=your-smtp-password-or-api-key

# Frontend URL (for CORS configuration)
CLIENT_URL=https://devstorm.dev

# Optional: API server URL (if different from frontend)
API_URL=https://api.devstorm.dev
